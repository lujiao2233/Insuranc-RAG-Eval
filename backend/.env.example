# 应用配置
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1800

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/rag_evaluation

# MySQL工具脚本通用配置（create_tables_mysql56.py / import_data_mysql56.py）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=RAGEVAL

# migrate_data.py 本地库配置（源库）
LOCAL_MYSQL_HOST=localhost
LOCAL_MYSQL_PORT=3306
LOCAL_MYSQL_USER=root
LOCAL_MYSQL_PASSWORD=your-local-mysql-password
LOCAL_MYSQL_DATABASE=rag_evaluation

# migrate_data.py 远程库配置（目标库）
REMOTE_MYSQL_HOST=localhost
REMOTE_MYSQL_PORT=3306
REMOTE_MYSQL_USER=root
REMOTE_MYSQL_PASSWORD=your-remote-mysql-password
REMOTE_MYSQL_DATABASE=RAGEVAL

# Qwen API配置（可选，不配置则使用模拟服务）
QWEN_API_KEY=your-qwen-api-key

# 文件上传配置
UPLOAD_DIR=data/uploads
MAX_FILE_SIZE=52428800
